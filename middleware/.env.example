PORT=3001
NODE_ENV=development
LOG_LEVEL=info
ALLOWED_ORIGIN=http://localhost:5173

# Development runs without local infrastructure by default.
# MOCK_MODE keeps Partner, GroundX, and LLM calls deterministic while still
# requiring local keys to exercise the same secret plumbing as production.
MOCK_MODE=true
# Set APP_REPOSITORY_MODE=mysql and fill these values for real MySQL.
APP_REPOSITORY_MODE=memory
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DATABASE=groundx_app
# MYSQL_USER=groundx_app
# MYSQL_PASSWORD=change-me

SESSION_SECRET=replace-with-a-long-random-secret
GROUNDX_BASE_URL=https://api.groundx.ai/api/v1
# Required for scaffold setup; ignored by upstream clients while MOCK_MODE=true.
GROUNDX_PARTNER_API_KEY=
GROUNDX_ANON_API_KEY=

LLM_BASE_URL=https://api.openai.com/v1
LLM_SERVICE=
# Required for scaffold setup; ignored by upstream clients while MOCK_MODE=true.
LLM_API_KEY=
LLM_AUTH_HEADER_NAME=Authorization
LLM_AUTH_SCHEME=Bearer
LLM_MODEL_ID=
